{
  "permissions": {
    "allow": [
      "Bash(ls*)",
      "Bash(pwd)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(grep*)",
      "Bash(rg*)",
      "Bash(find*)",
      "Bash(which*)",
      "Bash(echo*)",
      "Bash(wc*)",
      "Bash(diff*)",
      "Bash(tree*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch)",
      "Bash(./verify.sh)",
      "Bash(sh*gate.sh)",
      "WebFetch",
      "WebSearch"
    ],
    "ask": [
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push)",
      "Bash(git checkout*)",
      "Bash(git merge*)",
      "Bash(mv*)",
      "Bash(cp*)",
      "Bash(mkdir*)"
    ],
    "deny": [
      "Bash(rm*)",
      "Bash(sudo*)",
      "Bash(git push*--force*)",
      "Bash(git push*-f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean*)",
      "Bash(mkfs*)",
      "Bash(dd*)",
      "Bash(:(){:|:&};:)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      { "matcher": "Bash",
        "hooks": [ { "type": "command", "command": "sh \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard.sh\"" } ] }
    ]
  }
}
